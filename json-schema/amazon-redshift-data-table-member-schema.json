{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TableMember",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the table"
    },
    "type": {
      "type": "string",
      "description": "The type of the table (TABLE, VIEW, etc.)"
    },
    "schema": {
      "type": "string",
      "description": "The schema that contains the table"
    }
  }
}